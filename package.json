{
  "name": "kapanlibur-api",
  "version": "1.2.3",
  "description": "API untuk informasi hari libur nasional Indonesia",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "lint": "eslint src/**/*.js",
    "prepare": "husky",
    "docker:build": "docker build -t kapanlibur-api:latest .",
    "docker:run": "docker run -p 3000:3000 kapanlibur-api:latest",
    "docker:logs": "docker logs -f kapanlibur-api"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "eslint": "^10.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "nodemon": "^3.1.14"
  }
}
